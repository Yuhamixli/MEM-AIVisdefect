# Cursor — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_xxxxxxxx

# Feishu app (MEM-AIVisdefect-Agent)
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx
# Optional; auto-resolved from /bot/v3/info
# FEISHU_BOT_OPEN_ID=ou_xxxxxxxx

# cloud (default) | local
CURSOR_RUNTIME=cloud
CURSOR_CLOUD_REPO=https://github.com/Yuhamixli/MEM-AIVisdefect
CURSOR_CLOUD_REF=main

# Only for CURSOR_RUNTIME=local
# REPO_CWD=A:/Projects/MEM-AIVisdefect

CURSOR_MODEL=composer-2.5
REQUIRE_MENTION=true
MAX_REPLY_CHARS=3500
